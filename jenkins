pipeline {
    agent any

    environment {
        DOCKER_HUB_USERNAME = 'sharath198'
        IMAGE_NAME = 'nestjs-employee-crud'
        IMAGE_TAG = "${BUILD_NUMBER}"
        FULL_IMAGE = "${DOCKER_HUB_USERNAME}/${IMAGE_NAME}:${IMAGE_TAG}"
        LATEST_IMAGE = "${DOCKER_HUB_USERNAME}/${IMAGE_NAME}:latest"

        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/9182029380/Nestjs-curd-voya-employee.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build Application') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat "docker build -t ${FULL_IMAGE} -t ${LATEST_IMAGE} ."
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDENTIALS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    bat "docker login -u %DOCKER_USER% -p %DOCKER_PASS%"
                    bat "docker push ${FULL_IMAGE}"
                    bat "docker push ${LATEST_IMAGE}"
                    bat "docker logout"
                }
            }
        }

        // ✅ NEW STAGE: Deploy to Kubernetes
        stage('Deploy to Kubernetes') {
            steps {
                echo "Deploying to Kubernetes..."

                // Replace image dynamically
                bat """
                kubectl set image deployment/nestjs-employee-app \
                nestjs-employee-app=${FULL_IMAGE} \
                --namespace=default
                """

                // Apply YAML (first time or updates)
                bat "kubectl apply -f k8s/"
            }
        }
    }

    post {
        success {
            echo "✅ Deployed successfully: ${FULL_IMAGE}"
        }
        failure {
            echo "❌ Pipeline failed"
        }
    }
}